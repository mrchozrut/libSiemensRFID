<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Public NuGet.org feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Azure DevOps Artifacts feed - update the feed URL as needed -->
    <add key="Adient-Lucenec" value="https://pkgs.dev.azure.com/adient/Lucenec_0798_OT/_packaging/SiemensRFID/nuget/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="Adient-Lucenec">
      <package pattern="Adient.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
